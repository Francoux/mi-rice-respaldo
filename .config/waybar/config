{
    "layer": "top",
    "height": 50,
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": [
        "custom/notification",
        "clock",
        "group/music"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/expand",
        "bluetooth",
        "network",
        "pulseaudio",
        "custom/brightness",
        "backlight",
        "battery",
        "custom/power"
    ],
    "custom/notification": {
        "tooltip-format": "Open notifications panel",
        "format": "",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%I:%M:%S %p} ",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#fAfBfC'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_up",
            "on-click": "shift_down"
        }
    },
    "group/music": {
        "orientation": "horizontal",
        "modules": [
            "custom/spotify-label",
            "custom/prev",
            "custom/play",
            "custom/next"
        ]
    },
    "custom/spotify-label": {
        "format": " {}",
        "max-length": 30,
        "exec": "playerctl -p spotify metadata --format '{{title}} - {{artist}}' 2> /dev/null",
        "interval": 1,
        "on-click": "hyprctl dispatch focuswindow class:Spotify",
        "on-click-right": "playerctl -p spotify play-pause",
        "escape": true,
        "tooltip": false
    },
    "custom/prev": {
        "format": "󰒮",
        "on-click": "playerctl -p spotify previous",
        "tooltip": false
    },
    "custom/play": {
        "format": "{}",
        "exec": "playerctl -p spotify status 2> /dev/null | grep 'Playing' > /dev/null && echo '󰏤' || echo '󰐊'",
        "interval": 1,
        "on-click": "playerctl -p spotify play-pause",
        "tooltip": false
    },
    "custom/next": {
        "format": "󰒭",
        "on-click": "playerctl -p spotify next",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "format": "",
        "format-icons": {
            "active": "",
            "default": "",
            "empty": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "group/expand": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 600,
            "transition-left-to-right": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
            "custom/pacman", 
            "tray",
            "custom/colorpicker",
            "power-profiles-daemon",
            "custom/separator"
        ]
    },
    "custom/expand": {
        "format": "",
        "tooltip": false
    },
    "custom/pacman": {
        "format": "󰅢 {}",
        "interval": 3600,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "kitty sh -c 'yay -Syu; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip-format": "Pending Updates"
    },
    "tray": {
        "reverse-direction": true,
        "icon-size": 14,
        "spacing": 10
    },
    "custom/colorpicker": {
        "format": "{}",
        "return-type": "json",
        "interval": "once",
        "exec": "/home/franco/.config/waybar/scripts/colorpicker.sh -j",
        "on-click": "/home/franco/.config/waybar/scripts/colorpicker.sh",
        "signal": 1
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
        }
    },
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },
    "bluetooth": {
        "format-on": "󰂯",
        "format-off": "BT-off",
        "format-disabled": "󰂲",
        "format-no-controller": "",
        "format-connected-battery": "{device_battery_percentage}% 󰂯",
        "format-alt": "{device_alias} 󰂯",
        // USAMOS HYPRCTL DISPATCH EXEC PARA QUE WAYBAR NO ESPERE NADA
        "on-click": "hyprctl dispatch exec '/home/franco/.config/waybar/scripts/toggle.sh bt bluetuith'",
        "tooltip": false
    },
    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "",
        // USAMOS HYPRCTL DISPATCH EXEC
        "on-click": "hyprctl dispatch exec '/home/franco/.config/waybar/scripts/toggle.sh wifi nmtui'",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "default": [
                "",
                ""
            ]
        },
        "scroll-step": 10,
        // USAMOS HYPRCTL DISPATCH EXEC
        "on-click": "hyprctl dispatch exec '/home/franco/.config/waybar/scripts/toggle.sh audio pulsemixer'",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },
    "custom/brightness": {
        "format": "{icon} {percentage}%",
        "format-icons": [
            "\uDB80\uDCDE",
            "\uDB80\uDCDF",
            "\uDB80\uDCE0"
        ],
        "return-type": "json",
        "exec": "ddcutil getvcp 10 | grep -oP 'current.*?=\\s*\\K[0-9]+' | { read x; echo '{\"percentage\":'${x}'}'; }",
        "on-scroll-up": "ddcutil setvcp 10 + 10",
        "on-scroll-down": "ddcutil setvcp 10 - 10",
        "on-click": "/home/franco/.config/waybar/scripts/night-mode.sh",
        "tooltip-format": "Screen brightness",
        "exec-on-event": true,
        "interval": "once",
        "exec-if": "command -v ddcutil"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "\uDB80\uDCDE",
            "\uDB80\uDCDF",
            "\uDB80\uDCE0"
        ],
        "on-scroll-up": "brightnessctl -n set 5%+",
        "on-scroll-down": "brightnessctl -n set 5%-",
        "on-click": "/home/franco/.config/waybar/scripts/night-mode.sh",
        "tooltip-format": "Screen brightness"
    },
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% 󰂄",
        "format-plugged": "{capacity}% 󰂄 ",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "󰁻",
            "󰁼",
            "󰁾",
            "󰂀",
            "󰂂",
            "󰁹"
        ]
    },
    "custom/power": {
        "format": "⏻",
        "tooltip-format": "Open power menu",
        "on-click": "wlogout -b 4"
    }
}