[general]
# Velocidad de actualización (frames por segundo)
framerate = 60

# Sensibilidad (ajusta con las flechas si las barras son muy bajas)
sensitivity = 100

# Número de barras (0 para automático según el ancho de terminal)
bars = 0

[input]
# Método para PipeWire/Spotify
method = pipewire
source = auto

[output]
# Método de salida visual
method = ncurses

[color]
# Degradado basado en tu captura de pantalla (tonos verde-azulado/turquesa)
gradient = 1
gradient_count = 6
gradient_color_1 = '#94e2d5'
gradient_color_2 = '#89dceb'
gradient_color_3 = '#74c7ec'
gradient_color_4 = '#89dceb'
gradient_color_5 = '#94e2d5'
gradient_color_6 = '#a6e3a1'

[smoothing]
# Hace que el movimiento sea más fluido
monstercat = 1
waves = 0
noise_reduction = 77

[eq]
# Ecualización para que las barras bajas y altas se vean equilibradas
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1
